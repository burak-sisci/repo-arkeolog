# ── Veri katmanı ─────────────────────────────────────────────
DATABASE_URL=postgresql://repoarkeolog:repoarkeolog@localhost:5432/repoarkeolog
REDIS_URL=redis://localhost:6379/0
# Qdrant opsiyonel — boş bırakılırsa embedding adımı atlanır (chat/RAG kapanır).
QDRANT_URL=

# ── LLM anahtarları ──────────────────────────────────────────
# Cerebras 5 ajanın hepsini çalıştırır.
CEREBRAS_API_KEY=
# Gemini opsiyonel — yalnız embedding ve eski entegrasyonlar için.
GEMINI_API_KEY=
# Groq opsiyonel — yedek LLM olarak kalır.
GROQ_API_KEY=

# ── Web ───────────────────────────────────────────────────────
# CORS origin listesi (virgülle). "*" sadece geliştirme için.
# Örn: "https://app.example.com,https://staging.app.example.com"
CORS_ORIGINS=*

# ── Webhook (opsiyonel) ──────────────────────────────────────
ADMIN_WEBHOOK_URL=
